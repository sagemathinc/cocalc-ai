# Generated package outputs.  This file is intentionally under src/ so ripgrep
# respects it even when commands are run from /home/user/cocalc-ai/src.
packages/*/build/
packages/*/dist/
packages/*/dist-*/
packages/*/dist-ts/

# Generated/minified bundle artifacts.  Keep these out of normal ripgrep
# searches even when the artifact is tracked or a gitignore rule is ineffective.
**/*.bundle.js
**/*.bundle.css
**/*.min.js
**/*.min.css
**/*.js.map
**/*.css.map
