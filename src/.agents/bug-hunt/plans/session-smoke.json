{
  "name": "session-smoke",
  "steps": [
    {
      "name": "wait body",
      "action": {
        "name": "wait_for_selector",
        "selector": "body",
        "state": "visible",
        "timeout_ms": 15000
      }
    },
    {
      "name": "assert route",
      "assert": "return /^\\/projects\\/[0-9a-f-]+\\/(project-home|files)\\/?$/.test(window.location.pathname);",
      "retries": 1,
      "recovery": "reload"
    },
    {
      "name": "assert CoCalc title is visible",
      "assert": "return typeof document.title === 'string' && document.title.includes('CoCalc');"
    },
    {
      "name": "assert project navigation shell is visible",
      "assert": "const body = document.body.innerText; return body.includes('Files') && body.includes('New');"
    }
  ]
}
