{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "rootDir": "./",
    "outDir": "dist",
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "baseUrl": ".",
    "paths": {
      "@cocalc/ai": ["../ai"],
      "@cocalc/ai/*": ["../ai/*"],
      "@cocalc/backend": ["../backend"],
      "@cocalc/backend/*": ["../backend/*"],
      "@cocalc/chat": ["../chat"],
      "@cocalc/chat/*": ["../chat/*"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "**/test/**",
    "**/__tests__/**",
    "**/__test__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.test.jsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx",
    "jest.config.cjs"
  ],
  "references": [
    { "path": "../ai" },
    { "path": "../backend" },
    { "path": "../chat" }
  ]
}
