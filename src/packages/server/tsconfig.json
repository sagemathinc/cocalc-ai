{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ESNext"],
    "rootDir": "./",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@langchain/core/*": ["../ai/node_modules/@langchain/core/dist/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/test/**",
    "**/__tests__/**",
    "**/__test__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.test.jsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx",
    "jest.config.js"
  ],
  "references": [
    { "path": "../backend" },
    { "path": "../conat" },
    { "path": "../database" },
    { "path": "../cloud" },
    { "path": "../file-server" },
    { "path": "../project-runner" },
    { "path": "../project-proxy" },
    { "path": "../util" }
  ]
}
