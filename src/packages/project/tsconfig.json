{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ES2021"],
    "target": "ES2021",
    "rootDir": "./",
    "outDir": "dist"
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "jupyter/test",
    "build",
    "**/test/**",
    "**/__tests__/**",
    "**/__test__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.test.jsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx",
    "jest.config.js"
  ],
  "references": [
    { "path": "../backend" },
    { "path": "../comm" },
    { "path": "../jupyter" },
    { "path": "../conat" },
    { "path": "../sync" },
    { "path": "../sync-client" },
    { "path": "../util" }
  ]
}
