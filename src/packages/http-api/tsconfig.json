{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./",
    "outDir": "dist",
    "declarationDir": "dist-types",
    "lib": ["ESNext"],
    "paths": {
      "@langchain/core/*": ["../ai/node_modules/@langchain/core/dist/*"]
    }
  },
  "include": [
    "index.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "pages/**/*.ts",
    "pages/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-types",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx"
  ],
  "references": [
    { "path": "../backend" },
    { "path": "../conat" },
    { "path": "../database" },
    { "path": "../frontend" },
    { "path": "../server" },
    { "path": "../util" }
  ]
}
