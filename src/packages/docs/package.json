{
  "name": "@cocalc/docs",
  "version": "0.1.0",
  "description": "Versioned CoCalc-ai documentation content and search helpers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./verification": {
      "types": "./dist/verification.d.ts",
      "default": "./dist/verification.js"
    }
  },
  "typesVersions": {
    "*": {
      "verification": [
        "dist/verification.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "pnpm exec tsc --build --force",
    "clean": "rm -rf dist node_modules tsconfig.tsbuildinfo",
    "gaps": "pnpm build && node dist/verify.js --gaps",
    "verify": "pnpm build && node dist/verify.js"
  },
  "files": [
    "dist/**",
    "package.json"
  ],
  "author": "SageMath, Inc.",
  "license": "SEE LICENSE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/sagemathinc/cocalc"
  }
}
