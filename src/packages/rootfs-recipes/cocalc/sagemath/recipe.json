{
  "id": "cocalc/sagemath",
  "version": 1,
  "description": "Build SageMath from source, install Sage/Python Jupyter kernels, and expose Sage's Python as the default Python.",
  "timeout": 28800,
  "inputs": {
    "method": { "type": "string", "default": "source" },
    "version": { "type": "string", "default": "10.9" },
    "source_url": {
      "type": "string",
      "default": "https://github.com/sagemath/sage.git"
    },
    "build_dir": { "type": "string", "default": "/tmp/cocalc-sagemath-build" },
    "jobs": { "type": "string", "default": "auto" },
    "clean_build_dir": { "type": "string", "default": "true" },
    "install_recommended_apt_packages": { "type": "string", "default": "true" },
    "install_sagetex": { "type": "string", "default": "true" },
    "packages": {
      "type": "array",
      "default": ["sagemath", "sagemath-jupyter"]
    },
    "prefix": { "type": "string", "default": "/usr/local/sage" },
    "micromamba_prefix": { "type": "string", "default": "/opt/micromamba" },
    "conda_packages": { "type": "array", "default": ["sage"] },
    "owner_uid": { "type": "string", "default": "2001" },
    "owner_gid": { "type": "string", "default": "2001" }
  },
  "run": { "shell": "bash", "script": "install.sh" },
  "verify": { "shell": "bash", "script": "verify.sh" },
  "contributes": {
    "metadata": {
      "family": "sagemath",
      "tags": ["sagemath", "math", "jupyter"]
    },
    "theme": {
      "icon": "calculator",
      "color": "#ffffff",
      "accent_color": "#0f766e"
    },
    "content": {
      "version": 1,
      "title": "SageMath",
      "subtitle": "SageMath built from source with Sage and Python Jupyter kernels.",
      "highlights": ["SageMath 10.9", "Sage Python", "Jupyter"],
      "actions": [
        {
          "kind": "external-link",
          "label": "SageMath documentation",
          "url": "https://doc.sagemath.org/"
        }
      ]
    }
  }
}
