{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "dist"
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/test/**",
    "**/__tests__/**",
    "**/__test__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.test.jsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx",
    "jest.config.js"
  ],
  "references_comment": "Do not define path:../comm because that causes a circular references.",
  "references": [{ "path": "../util", "path": "../sync" }]
}
