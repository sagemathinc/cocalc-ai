{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "rootDir": "./",
    "outDir": "dist",
    "paths": {
      "@nebius/js-sdk/api/*": ["./node_modules/@nebius/js-sdk/dist/esm/api/*"],
      "@nebius/js-sdk/runtime/*": [
        "./node_modules/@nebius/js-sdk/dist/esm/runtime/*"
      ]
    }
  },
  "references": [{ "path": "../backend" }, { "path": "../util" }],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "**/test/**",
    "**/__tests__/**",
    "**/__test__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.test.jsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx",
    "jest.config.cjs"
  ]
}
