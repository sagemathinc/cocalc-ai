{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@cocalc/conat": ["../conat"],
      "@cocalc/conat/*": ["../conat/*"],
      "@cocalc/lite": ["../lite"],
      "@cocalc/lite/*": ["../lite/*"]
    }
  },
  "exclude": [
    "dist",
    "node_modules",
    "build",
    "**/*.test.ts",
    "jest.config.js"
  ],
  "references": [{ "path": "../lite" }]
}
