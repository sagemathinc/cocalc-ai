{
  "name": "@cocalc/cli",
  "version": "1.0.1",
  "description": "CoCalc command line interface",
  "bin": {
    "cocalc": "./dist/bin/cocalc.js",
    "cocalc-cli": "./dist/bin/cocalc.js",
    "cli": "./dist/bin/cocalc.js"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "cli": "node ./dist/bin/cocalc.js",
    "cocalc": "node ./dist/bin/cocalc.js",
    "build": "pnpm exec tsc --build && node ./scripts/ensure-dist.js && pnpm run link:bins",
    "clean": "rm -rf dist build tsconfig.tsbuildinfo sea/sea-prep.blob sea/cocalc.js sea/sea.term",
    "link:bins": "node ./scripts/link-bins.js",
    "postinstall": "pnpm run link:bins",
    "build:bundle": "bash ./sea/build-bundle.sh",
    "run:bundle": "node ./build/bundle/index.js",
    "sea": "bash ./sea/build-sea.sh",
    "sea:signed": "cd sea && make signed-tar",
    "publish:sea": "cd sea && ./publish-sea.sh",
    "publish:sea:signed": "pnpm sea:signed && pnpm publish:sea",
    "publish:site": "cd site && ./publish-site.sh",
    "test": "pnpm build && node --test $(find dist -name '*.test.js' -print)"
  },
  "files": [
    "dist/**",
    "sea/**",
    "site/**",
    "install.sh",
    "package.json",
    "README.md"
  ],
  "exports": {
    "./api/tasks": {
      "types": "./dist/api/tasks.d.ts",
      "default": "./dist/api/tasks.js"
    },
    "./api/text": {
      "types": "./dist/api/text.d.ts",
      "default": "./dist/api/text.js"
    },
    "./api/jupyter": {
      "types": "./dist/api/jupyter.d.ts",
      "default": "./dist/api/jupyter.js"
    },
    "./api/timetravel": {
      "types": "./dist/api/timetravel.d.ts",
      "default": "./dist/api/timetravel.js"
    },
    "./api/export": {
      "types": "./dist/api/export.d.ts",
      "default": "./dist/api/export.js"
    },
    "./api/import": {
      "types": "./dist/api/import.d.ts",
      "default": "./dist/api/import.js"
    }
  },
  "author": "SageMath, Inc.",
  "license": "SEE LICENSE.md",
  "dependencies": {
    "@cocalc/app-notebook": "workspace:*",
    "@cocalc/app-tasks": "workspace:*",
    "@cocalc/chat": "workspace:*",
    "@cocalc/comm": "workspace:*",
    "@cocalc/conat": "workspace:*",
    "@cocalc/export": "workspace:*",
    "@cocalc/util": "workspace:*",
    "ascii-table3": "^1.0.1",
    "commander": "^14.0.1",
    "playwright-core": "^1.57.0",
    "reflect-sync": "0.15.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@vercel/ncc": "^0.38.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sagemathinc/cocalc"
  },
  "homepage": "https://github.com/sagemathinc/cocalc/tree/master/src/packages/cli"
}
