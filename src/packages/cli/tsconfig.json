{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@cocalc/app-tasks": [
        "../apps/tasks/src"
      ],
      "@cocalc/app-tasks/*": [
        "../apps/tasks/src/*"
      ],
      "@cocalc/conat": [
        "../conat"
      ],
      "@cocalc/conat/*": [
        "../conat/*"
      ],
      "@cocalc/export": [
        "../export"
      ],
      "@cocalc/export/*": [
        "../export/*"
      ],
      "@cocalc/util": [
        "../util"
      ],
      "@cocalc/util/*": [
        "../util/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ],
  "references": [
    {
      "path": "../apps/tasks"
    },
    {
      "path": "../conat"
    },
    {
      "path": "../export"
    },
    {
      "path": "../util"
    }
  ]
}
