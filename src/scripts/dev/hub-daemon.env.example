# Copy this file to ../../.local/hub-daemon.env and edit as needed.
#
# Example:
#   cp src/scripts/dev/hub-daemon.env.example src/.local/hub-daemon.env
#
# Notes:
#   - Plain NAME=value settings below configure the daemon wrapper itself.
#   - The bay / cluster topology variables below are also propagated to the hub.
#   - Any other additional environment variables that the hub process should
#     inherit must still be written with explicit export statements.
# Hub process command (run from src/)
HUB_CMD="./packages/hub/bin/start.sh postgres"

# Hub HTTP port and baseline runtime flags
HUB_PORT=9100
HUB_BIND_HOST=localhost
# set to 1 if using non-loopback bind host for local smoke testing.
HUB_ALLOW_INSECURE_HTTP_MODE=0
HUB_DISABLE_NEXT=1
HUB_DEBUG="cocalc:*"

# Log files
HUB_DEBUG_FILE=""        # default: src/log
HUB_STDOUT_LOG=""        # default: src/.local/hub-daemon/hub.stdout.log

# Local software artifact serving
#
# packages root used by /software routes in hub
HUB_SOFTWARE_PACKAGES_ROOT=""  # default: src/packages
#
# if set to 1, force bootstrap/software URLs to use this local hub
HUB_USE_LOCAL_SOFTWARE=1
#
# optional explicit host ip used in forced base URL; if empty auto-detected
HUB_HOST_IP=""
#
# optional explicit base URL, e.g. http://192.168.1.10:9100/software
# if set, it overrides HUB_USE_LOCAL_SOFTWARE/HUB_HOST_IP logic
HUB_SOFTWARE_BASE_URL_FORCE=""

# optional explicit node path used when launching the hub daemon.
# leave empty for auto-detect.
HUB_NODE_BIN=""

# optional explicit URL used for self-host connector pairing callback.
# default when empty: http://127.0.0.1:${HUB_PORT}
HUB_SELF_HOST_PAIR_URL=""

# optional cloudflared pid file used by launchpad cloudflare tunnel management.
# restart keeps this process; stop terminates it.
HUB_CLOUDFLARED_PID_FILE=""

# Conat connection limits for local multi-bay development.
# These defaults are intentionally higher than production-style defaults because
# attached bays keep many long-lived internal hub-authenticated Conat clients.
COCALC_CONAT_MAX_CONNECTIONS_PER_USER=500
COCALC_CONAT_MAX_CONNECTIONS_PER_HUB_USER=1000
COCALC_CONAT_MAX_CONNECTIONS=10000

# Set to 1 to log each cached Conat client creation, which is useful when
# auditing why a bay is holding many seed-bay sockets.
COCALC_CONAT_LOG_CLIENT_CREATION=0
# Set to 1 as well if you also want a stack trace for each client creation log.
COCALC_CONAT_LOG_CLIENT_CREATION_STACK=0

# Bay / cluster topology
#
# For ordinary local development, leave these at the defaults.
# For multi-bay development, point HUB_DEV_CLUSTER_CONFIG at a JSON file.
# Copy `src/scripts/dev/hub-cluster.example.json` to `src/.local/hub-cluster.json`
# and edit it to describe any number of bays.
COCALC_BAY_ID="bay-0"
COCALC_BAY_LABEL=""
COCALC_BAY_REGION=""
COCALC_CLUSTER_ROLE="standalone"   # standalone | seed | attached
COCALC_CLUSTER_SEED_BAY_ID=""
COCALC_CLUSTER_SEED_CONAT_SERVER=""
COCALC_CLUSTER_SEED_CONAT_PASSWORD=""
HUB_DEV_CLUSTER_CONFIG=""
# Optional inline alternative to HUB_DEV_CLUSTER_CONFIG. Leave empty in normal use.
HUB_DEV_CLUSTER_JSON=""

# Optional guarded projection-backed read modes.
# Valid values: off, prefer, only
export COCALC_ACCOUNT_PROJECT_INDEX_PROJECT_LIST_READS=""
export COCALC_ACCOUNT_COLLABORATOR_INDEX_COLLABORATOR_READS=""
