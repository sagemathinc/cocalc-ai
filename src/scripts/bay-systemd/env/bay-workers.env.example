# Copy to /etc/cocalc/bay-workers.env and tune worker behavior.

# Keep one browser-facing hub worker by default. Production bays can raise this
# after deploying the sticky frontdoor, which pins each browser to one healthy
# worker and reassigns it when that worker is drained or unhealthy.
COCALC_BAY_WORKER_COUNT=1

# Optional per-worker overrides.
COCALC_BAY_WORKER_NODE_OPTIONS=
COCALC_BAY_WORKER_EXTRA_ENV=
