# Copy to /etc/cocalc/bay-workers.env and tune worker behavior.

# Keep one browser-facing hub worker until Rocket has shared/sticky hub-worker
# Conat routing. Multiple independent workers can make browser-session and
# direct project-host auth routing probabilistic.
COCALC_BAY_WORKER_COUNT=1

# Optional per-worker overrides.
COCALC_BAY_WORKER_NODE_OPTIONS=
COCALC_BAY_WORKER_EXTRA_ENV=
