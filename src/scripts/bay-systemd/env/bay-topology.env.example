# Copy to /etc/cocalc/bay-topology.env for multibay deployments.
#
# Standalone bays can leave this file as-is. Multibay automation should render
# the same cluster topology on every bay, using private/internal cloud IPs for
# peer-health URLs.

COCALC_CLUSTER_ID=standalone
COCALC_CLUSTER_ROLE=standalone
COCALC_CLUSTER_SEED_BAY_ID=bay-1
COCALC_CLUSTER_BAY_IDS=bay-1
COCALC_CLUSTER_TOPOLOGY_EPOCH=0

# Bind to the VM internal IP for multibay clusters. Keep 127.0.0.1 for
# standalone bays.
COCALC_BAY_PEER_HEALTH_HOST=127.0.0.1
COCALC_BAY_PEER_HEALTH_PORT=9402
COCALC_BAY_PEER_HEALTH_PATH=/peer-health
COCALC_BAY_PEER_HEALTH_TIMEOUT_S=5
COCALC_BAY_PEER_LOCAL_HEALTH_TIMEOUT_S=3

# Space-separated bay-id=url entries. Use private/internal IPs, not public DNS.
# Example:
# COCALC_CLUSTER_PEER_HEALTH_URLS="bay-0=http://10.206.0.21:9402/peer-health bay-1=http://10.206.0.22:9402/peer-health"
COCALC_CLUSTER_PEER_HEALTH_URLS=
