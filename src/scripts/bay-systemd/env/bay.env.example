# Copy to /etc/cocalc/bay.env and replace placeholders.

COCALC_BAY_ID=bay-1
COCALC_BAY_ROOT=/mnt/cocalc/bays/bay-1

COCALC_BAY_RELEASES_DIR=/opt/cocalc/bay/releases
COCALC_BAY_CURRENT_LINK=/opt/cocalc/bay/current
COCALC_BAY_NODE_VERSION=26.2.0
COCALC_BAY_NODE_BIN=/opt/cocalc/nvm/versions/node/v26.2.0/bin/node

COCALC_BAY_STATE_DIR=/mnt/cocalc/bays/bay-1/state
COCALC_BAY_RUN_DIR=/mnt/cocalc/bays/bay-1/run
COCALC_BAY_LOG_DIR=/mnt/cocalc/bays/bay-1/logs
COCALC_BAY_BACKUP_DIR=/mnt/cocalc/bays/bay-1/backups
COCALC_BIN_PATH=/mnt/cocalc/bays/bay-1/bin

COCALC_BAY_POSTGRES_HOST=127.0.0.1
COCALC_BAY_POSTGRES_PORT=5432
COCALC_BAY_POSTGRES_DATA_DIR=/mnt/cocalc/bays/bay-1/postgres
COCALC_BAY_POSTGRES_DB=cocalc_bay
COCALC_BAY_POSTGRES_USER=cocalc

COCALC_BAY_PERSIST_HOST=127.0.0.1
COCALC_BAY_PERSIST_PORT=9202
COCALC_BAY_PERSIST_HEALTH_PATH=/healthz

COCALC_BAY_ROUTER_HOST=127.0.0.1
COCALC_BAY_ROUTER_PORT=9102
COCALC_BAY_ROUTER_HEALTH_PATH=/healthz

COCALC_BAY_HUB_BIND_HOST=127.0.0.1
COCALC_BAY_HUB_BASE_PORT=9300
COCALC_BAY_HUB_HEALTH_PATH=/alive

COCALC_BAY_FRONTDOOR_HOST=127.0.0.1
COCALC_BAY_FRONTDOOR_PORT=9400
COCALC_BAY_FRONTDOOR_HEALTH_PATH=/_cocalc/frontdoor/healthz
COCALC_BAY_FRONTDOOR_DRAIN_FILE=/mnt/cocalc/bays/bay-1/state/frontdoor-drain-workers

COCALC_BAY_MIN_HEALTHY_WORKERS=2
COCALC_BAY_HEALTH_TIMEOUT_S=15
COCALC_BAY_MIN_FREE_MB=1024
COCALC_BAY_CLOUDFLARED_SYSTEMD=1

# Replace these with the real bundle entrypoints.
COCALC_BAY_POSTGRES_CMD='/usr/lib/postgresql/16/bin/postgres -D "$COCALC_BAY_POSTGRES_DATA_DIR" -p "$COCALC_BAY_POSTGRES_PORT"'
COCALC_BAY_MIGRATE_CMD='/opt/cocalc/bay/current/libexec/bay-migrate-real'
COCALC_BAY_PERSIST_CMD='/opt/cocalc/bay/current/libexec/bay-conat-persist-real'
COCALC_BAY_ROUTER_CMD='/opt/cocalc/bay/current/libexec/bay-conat-router-real'
COCALC_BAY_HUB_CMD='/opt/cocalc/bay/current/libexec/bay-hub-real'
