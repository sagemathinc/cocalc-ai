# Optional overlay for the current CoCalc repo / bundle layout.
#
# Use this after /etc/cocalc/bay.env if the deployed bay bundle contains a
# built source tree like:
#   /opt/cocalc/bay/current/packages/project-host/dist/main.js
#   /opt/cocalc/bay/current/packages/hub/run/hub.js
#
# This overlay is intentionally transitional. It makes the starter scaffold more
# concrete for early implementation work, but it is not the final bay runtime
# contract.

COCALC_BAY_PROJECT_HOST_MAIN=/opt/cocalc/bay/current/packages/project-host/dist/main.js
COCALC_BAY_HUB_MAIN=/opt/cocalc/bay/current/packages/hub/run/hub.js

COCALC_BAY_PERSIST_CMD='CONAT_SERVER="http://127.0.0.1:${COCALC_BAY_ROUTER_PORT}" COCALC_PROJECT_HOST_CONAT_PERSIST_DAEMON=1 node "$COCALC_BAY_PROJECT_HOST_MAIN"'
COCALC_BAY_ROUTER_CMD='COCALC_PROJECT_HOST_CONAT_ROUTER_DAEMON=1 node "$COCALC_BAY_PROJECT_HOST_MAIN"'
COCALC_BAY_HUB_CMD='CONAT_SERVER="http://127.0.0.1:${COCALC_BAY_ROUTER_PORT}" PORT="$COCALC_BAY_WORKER_PORT" node "$COCALC_BAY_HUB_MAIN" --conat-api --proxy-server --hostname="$COCALC_BAY_HUB_BIND_HOST"'

# Do not rely on the generic hub server for bay migrations yet. It does not
# currently expose a clean migrate-and-exit mode for this use case.
COCALC_BAY_MIGRATE_CMD='echo "Define a bay-specific migration command before enabling cocalc-bay-migrations.service." >&2; exit 1'
