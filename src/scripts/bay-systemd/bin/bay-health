#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "${SCRIPT_DIR}/lib.sh"

router_only=false
peers=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --router-only)
      router_only=true
      shift
      ;;
    --peers)
      peers=true
      shift
      ;;
    -h|--help)
      cat <<'EOF'
Usage: bay-health [--router-only] [--peers]

Check local bay health. With --peers, also query authenticated peer-health
endpoints listed in COCALC_CLUSTER_PEER_HEALTH_URLS.
EOF
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if "$peers"; then
  if "$router_only"; then
    echo "--peers and --router-only cannot be combined" >&2
    exit 2
  fi
  set +e
  local_json="$("${BASH_SOURCE[0]}")"
  local_status=$?
  set -e
  token="$(peer_health_token || true)"
  python3 - \
    "$local_json" \
    "$local_status" \
    "$COCALC_BAY_ID" \
    "$COCALC_CLUSTER_ID" \
    "$COCALC_CLUSTER_SEED_BAY_ID" \
    "$COCALC_CLUSTER_BAY_IDS" \
    "$COCALC_CLUSTER_TOPOLOGY_EPOCH" \
    "$COCALC_CLUSTER_PEER_HEALTH_URLS" \
    "$COCALC_BAY_PEER_HEALTH_TIMEOUT_S" \
    "$token" <<'PY'
import json
import sys
import time
import urllib.error
import urllib.request

(
    local_json,
    local_status,
    bay_id,
    cluster_id,
    seed_bay_id,
    cluster_bay_ids,
    topology_epoch,
    peer_entries,
    timeout_s,
    token,
) = sys.argv[1:]

try:
    local = json.loads(local_json)
except Exception as err:
    local = {"ok": False, "error": f"invalid local health JSON: {err}", "raw": local_json}

peers = []
peers_ok = True
timeout = float(timeout_s)
for entry in peer_entries.split():
    if "=" not in entry:
        peers.append({"ok": False, "entry": entry, "error": "expected bay-id=url"})
        peers_ok = False
        continue
    peer_bay_id, url = entry.split("=", 1)
    if peer_bay_id == bay_id:
        continue
    record = {"bay_id": peer_bay_id, "url": url}
    if not token:
        record.update({"ok": False, "error": "missing COCALC_CLUSTER_SHARED_SECRET"})
        peers_ok = False
        peers.append(record)
        continue
    try:
        request = urllib.request.Request(
            url,
            headers={"Authorization": f"Bearer {token}", "Accept": "application/json"},
        )
        with urllib.request.urlopen(request, timeout=timeout) as response:
            body = response.read().decode("utf-8")
            payload = json.loads(body)
        record.update(
            {
                "ok": bool(payload.get("ok")),
                "status": response.status,
                "response": payload,
            }
        )
        if not record["ok"]:
            peers_ok = False
    except urllib.error.HTTPError as err:
        record.update({"ok": False, "status": err.code, "error": str(err)})
        peers_ok = False
    except Exception as err:
        record.update({"ok": False, "error": str(err)})
        peers_ok = False
    peers.append(record)

local_ok = local_status == "0" and bool(local.get("ok"))
result = {
    "ok": local_ok and peers_ok,
    "bay_id": bay_id,
    "cluster_id": cluster_id,
    "seed_bay_id": seed_bay_id,
    "cluster_bay_ids": [item for item in cluster_bay_ids.split(",") if item],
    "topology_epoch": topology_epoch,
    "checked_at_ms": int(time.time() * 1000),
    "local": local,
    "peers": peers,
}
print(json.dumps(result, sort_keys=True))
sys.exit(0 if result["ok"] else 1)
PY
  exit $?
fi

postgres_ok=true
persist_ok=true
router_ok=true
frontdoor_ok=true
healthy_workers=0

if ! "$router_only"; then
  if ! "${SCRIPT_DIR}/bay-postgres-check" >/dev/null 2>&1; then
    postgres_ok=false
  fi
  if ! http_check "$(persist_url)"; then
    persist_ok=false
  fi
  if ! "${SCRIPT_DIR}/bay-frontdoor-health" >/dev/null 2>&1; then
    frontdoor_ok=false
  fi
fi

if ! wait_for_http_check "$(router_url)" "router"; then
  router_ok=false
fi

if ! "$router_only"; then
  for worker_id in $(seq 1 "$COCALC_BAY_WORKER_COUNT"); do
    if "${SCRIPT_DIR}/bay-worker-health" "$worker_id" >/dev/null 2>&1; then
      healthy_workers=$((healthy_workers + 1))
    fi
  done
fi

if "$router_only"; then
  printf '{"ok":%s,"router_ok":%s}\n' "$router_ok" "$router_ok"
  "$router_ok"
  exit $?
fi

ok=false
if "$postgres_ok" && "$persist_ok" && "$router_ok" && "$frontdoor_ok" \
  && [[ "$healthy_workers" -ge "$COCALC_BAY_MIN_HEALTHY_WORKERS" ]]; then
  ok=true
fi

printf '{"ok":%s,"postgres_ok":%s,"persist_ok":%s,"router_ok":%s,"frontdoor_ok":%s,"healthy_workers":%s,"min_healthy_workers":%s}\n' \
  "$ok" "$postgres_ok" "$persist_ok" "$router_ok" "$frontdoor_ok" "$healthy_workers" \
  "$COCALC_BAY_MIN_HEALTHY_WORKERS"

"$ok"
