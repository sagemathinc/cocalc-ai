#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "${SCRIPT_DIR}/lib.sh"

worker_id="${1:-}"
if [[ ! "$worker_id" =~ ^[0-9]+$ ]]; then
  bay_log "usage: bay-frontdoor-drain <worker-id>"
  exit 1
fi

ensure_dirs
mkdir -p "$(dirname "$COCALC_BAY_FRONTDOOR_DRAIN_FILE")"
tmp="$(mktemp "${COCALC_BAY_FRONTDOOR_DRAIN_FILE}.XXXXXX")"
{
  if [[ -f "$COCALC_BAY_FRONTDOOR_DRAIN_FILE" ]]; then
    cat "$COCALC_BAY_FRONTDOOR_DRAIN_FILE"
  fi
  printf '%s\n' "$worker_id"
} | tr ', ' '\n\n' | awk '/^[0-9]+$/ { ids[$1]=1 } END { for (id in ids) print id }' | sort -n > "$tmp"
chmod 0644 "$tmp"
mv "$tmp" "$COCALC_BAY_FRONTDOOR_DRAIN_FILE"
bay_log "frontdoor draining worker ${worker_id}"
