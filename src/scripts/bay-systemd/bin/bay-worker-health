#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "${SCRIPT_DIR}/lib.sh"

worker_id="${1:-}"
if [[ -z "$worker_id" ]]; then
  bay_log "usage: bay-worker-health <worker-id>"
  exit 1
fi

if [[ -n "${COCALC_BAY_WORKER_HEALTH_CMD:-}" ]]; then
  export COCALC_BAY_WORKER_ID="$worker_id"
  export COCALC_BAY_WORKER_PORT
  COCALC_BAY_WORKER_PORT="$(worker_port "$worker_id")"
  run_env_cmd_once COCALC_BAY_WORKER_HEALTH_CMD
  exit 0
fi

if ! wait_for_http_check "$(worker_url "$worker_id")" "worker ${worker_id}"; then
  exit 1
fi

bay_log "worker ${worker_id} healthy"
