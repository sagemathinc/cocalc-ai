#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "${SCRIPT_DIR}/lib.sh"

current="$(current_version || true)"
previous="$(previous_version || true)"

printf 'bay_id=%s\n' "$COCALC_BAY_ID"
printf 'cluster_id=%s\n' "$COCALC_CLUSTER_ID"
printf 'cluster_role=%s\n' "$COCALC_CLUSTER_ROLE"
printf 'cluster_seed_bay_id=%s\n' "$COCALC_CLUSTER_SEED_BAY_ID"
printf 'cluster_bay_ids=%s\n' "$COCALC_CLUSTER_BAY_IDS"
printf 'cluster_topology_epoch=%s\n' "$COCALC_CLUSTER_TOPOLOGY_EPOCH"
printf 'peer_health_url=%s\n' "$(peer_health_url)"
printf 'current_version=%s\n' "${current:-unknown}"
printf 'previous_version=%s\n' "${previous:-unknown}"
printf 'worker_count=%s\n' "$COCALC_BAY_WORKER_COUNT"

if "${SCRIPT_DIR}/bay-health" >/dev/null 2>&1; then
  printf 'health=ok\n'
else
  printf 'health=failed\n'
fi
